{
  "name": "@workspace2k/backend",
  "version": "0.1.0",
  "description": "WorkSpace2K API Server",
  "main": "dist/apps/backend/src/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/backend/src/index.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node-dev --project tsconfig.seed.json --transpile-only prisma/seed.ts",
    "db:seed:prod": "node dist-seed/prisma/seed.js",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "@workspace2k/shared": "<rootDir>/../../packages/shared/src"
    },
    "clearMocks": true,
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "prisma": {
    "seed": "ts-node-dev --project tsconfig.seed.json --transpile-only prisma/seed.ts"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dockerode": "^4.0.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^3.3.38",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
