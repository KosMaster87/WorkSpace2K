NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200

DATABASE_URL=postgresql://ws2k:YOUR_DB_PASSWORD@localhost:5432/workspace2k_dev

JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# Seed — npm run db:seed
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE

# ── NPM Auto-Provisioning (optional) ────────────────────────────────────────
# Nginx Proxy Manager — Proxy Hosts automatisch anlegen wenn ein Stack gestartet wird.
# Leer lassen oder weglassen = NPM-Integration deaktiviert (kein Fehler, kein Lärm).
NPM_URL=http://localhost:81
NPM_EMAIL=admin@yourdomain.com
NPM_PASSWORD=CHANGE_ME
BASE_DOMAIN=yourdomain.com
