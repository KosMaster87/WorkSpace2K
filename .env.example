# ── WorkSpace2K — Produktions-Umgebungsvariablen ──────────────────────────────
# Diese Datei als .env kopieren und alle Werte anpassen.
# Die .env NIEMALS in Git committen (steht in .gitignore).

# PostgreSQL Passwort für den ws2k-Datenbanknutzer
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Vollständige Datenbank-URL — Hostname ist der Docker-Service-Name "db"
DATABASE_URL=postgresql://ws2k:CHANGE_ME_STRONG_PASSWORD@db:5432/workspace2k

# JWT Secret — mindestens 32 zufällige Bytes
# Generieren: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# CORS: URL unter der das Frontend erreichbar ist (kein trailing slash)
# Beispiel Synology: http://192.168.1.100 oder https://meine-domain.de
CORS_ORIGIN=http://localhost

# Admin-User für einmalige DB-Initialisierung (Seed)
# Nach "docker compose exec backend npm run db:seed:prod" können diese entfernt werden
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── NPM Auto-Provisioning (optional) ────────────────────────────────────────
# Nginx Proxy Manager — Proxy Hosts automatisch anlegen wenn ein Stack gestartet wird.
# Leer lassen oder weglassen = NPM-Integration deaktiviert (kein Fehler, kein Lärm).
# host.docker.internal wird via extra_hosts in compose.yaml auf den Host gemappt.
NPM_URL=http://host.docker.internal:81
NPM_EMAIL=admin@yourdomain.com
NPM_PASSWORD=CHANGE_ME
BASE_DOMAIN=yourdomain.com
