# coturn STUN/TURN Server Secrets

# Shared Secret für TURN-Authentifizierung (wird auch in Jitsi .env eingetragen)
TURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# Öffentliche IP des Servers — coturn muss von außen erreichbar sein
# Prüfen mit: curl -s https://api.ipify.org
TURN_EXTERNAL_IP=CHANGE_ME_PUBLIC_IP

# TURN Realm — typischerweise eine Subdomain
TURN_REALM=turn.dev2ksoftware.com
