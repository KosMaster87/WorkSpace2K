# Jitsi Meet Konfiguration
#
# VOR DEM START: Szenario wählen (Details → stacks/jitsi/compose.yaml)
#
# Szenario A — FritzBox direkt + Port-Forwarding UDP 10000:
#   JVB_ADVERTISE_IPS = öffentliche Router-IP (curl -s https://api.ipify.org)
#   TURN_HOST, TURN_SECRET leer lassen
#
# Szenario B — Double-NAT / kein Port-Forwarding (coturn nötig):
#   JVB_ADVERTISE_IPS = LAN-IP des Servers (192.168.188.25)
#   TURN_HOST = turn.dev2ksoftware.com
#   TURN_SECRET = selber Wert wie in stacks/coturn/.env

# ── Interne Secrets (auto-generiert beim ersten Start) ───────────────────
JICOFO_COMPONENT_SECRET=CHANGE_ME_openssl_rand_hex_16
JICOFO_AUTH_PASSWORD=CHANGE_ME_openssl_rand_hex_16
JVB_AUTH_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# ── Szenario A: direkte JVB-Verbindung ───────────────────────────────────
# Öffentliche IP des Routers (curl -s https://api.ipify.org)
# Bei Szenario B: LAN-IP eintragen (192.168.188.25)
JVB_ADVERTISE_IPS=CHANGE_ME_PUBLIC_IP

# ── Szenario B: TURN-Server (coturn) ─────────────────────────────────────
# Leer lassen für Szenario A
TURN_HOST=
TURN_PORT=3478
TURN_TRANSPORT=tcp
# Muss identisch mit TURN_SECRET in stacks/coturn/.env sein!
TURN_SECRET=
