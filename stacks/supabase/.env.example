# Supabase Secrets
#
# WICHTIG: ANON_KEY und SERVICE_KEY sind keine zufälligen Strings —
# sie sind JWT-Tokens die mit JWT_SECRET signiert werden müssen!
#
# Generieren auf: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Oder mit diesem Tool: https://jwt.io/
#
# Payload für ANON_KEY:
#   { "role": "anon", "iss": "supabase", "iat": <now>, "exp": <now+5years> }
#
# Payload für SERVICE_KEY:
#   { "role": "service_role", "iss": "supabase", "iat": <now>, "exp": <now+5years> }
#
# Beide mit HS256 + JWT_SECRET signieren.

# PostgreSQL Master-Passwort
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT Secret — Basis für alle API-Keys (mindestens 32 Zeichen)
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# API Keys — JWT-Tokens (NICHT zufällig, müssen generiert werden!)
# Siehe Kommentar oben für den Generierungsprozess.
ANON_KEY=CHANGE_ME_JWT_ANON
SERVICE_KEY=CHANGE_ME_JWT_SERVICE

# Realtime-Secrets (können zufällig sein)
DB_ENC_KEY=CHANGE_ME_openssl_rand_hex_32
SECRET_KEY_BASE=CHANGE_ME_openssl_rand_hex_32
